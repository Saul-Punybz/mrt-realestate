  <!-- Hero -->
  <section class="relative h-[40vh] min-h-[300px] -mt-20 pt-20">
    <img src={post.image} alt={post.title} class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-navy-900 via-navy-900/60 to-transparent"></div>
  </section>

  <!-- Article -->
  <article class="py-12 px-4">
    <div class="container mx-auto max-w-3xl">
      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 mb-6 -mt-20 relative z-10">
        <span class="bg-gold-500 text-navy-900 px-4 py-1 rounded-full text-sm font-bold">
          {post.category}
        </span>
        <span class="text-white/80 text-sm">{post.readTime} de lectura</span>
        <span class="text-white/80 text-sm">{formatDate(post.date)}</span>
      </div>

      <!-- Title -->
      <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-white mb-8 relative z-10">
        {post.title}
      </h1>

      <!-- Author -->
      <div class="flex items-center gap-4 mb-12 pb-8 border-b">
        <div class="w-12 h-12 bg-gold-500 rounded-full flex items-center justify-center flex-shrink-0">
          <span class="text-navy-900 font-serif font-bold text-lg">MR</span>
        </div>
        <div>
          <div class="font-medium text-navy-900">{post.author}</div>
          <div class="text-gray-500 text-sm">Agente Principal, MRT Real Estate</div>
        </div>
      </div>

      <!-- Content -->
      <div class="prose prose-lg max-w-none prose-headings:font-serif prose-headings:text-navy-900 prose-a:text-gold-600 prose-strong:text-navy-900">
        <Fragment set:html={post.content.replace(/\n/g, '<br>').replace(/## /g, '</p><h2>').replace(/### /g, '</p><h3>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n- /g, '</li><li>').replace(/<li>/g, '<ul><li>').replace(/<\/li>(?!<li>)/g, '</li></ul>').replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')} />
      </div>

      <!-- Share -->
      <div class="mt-12 pt-8 border-t">
        <div class="flex items-center justify-between">
          <span class="font-medium text-navy-900">Comparte este artículo:</span>
          <div class="flex gap-3">
            <a href="#" class="w-10 h-10 bg-navy-900 text-white rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="#" class="w-10 h-10 bg-navy-900 text-white rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
              </svg>
            </a>
            <a href="#" class="w-10 h-10 bg-navy-900 text-white rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Back to Blog -->
      <div class="mt-8">
        <a href="/blog" class="inline-flex items-center gap-2 text-gold-600 hover:text-navy-900 font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Volver al Blog
        </a>
      </div>
    </div>
  </article>

  <!-- CTA -->
  <section class="py-16 px-4 bg-navy-900">
    <div class="container mx-auto max-w-2xl text-center">
      <h2 class="font-serif text-3xl text-white mb-4">
        ¿Listo para Dar el Siguiente Paso?
      </h2>
      <p class="text-white/70 mb-8">
        Permítenos ayudarte a encontrar la propiedad perfecta en Puerto Rico.
      </p>
      <a href="/contact" class="inline-block bg-gold-500 text-navy-900 px-8 py-3 rounded-lg font-semibold hover:bg-white transition-colors">
        Contáctanos Hoy
      </a>
    </div>
  </section>
</BaseLayout>
