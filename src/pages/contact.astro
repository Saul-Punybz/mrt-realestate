---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/forms/ContactForm';
---

<BaseLayout
  title="Contacto"
  description="Contáctanos para encontrar tu propiedad ideal en Puerto Rico. Estamos aquí para ayudarte."
>
  <!-- Page Header -->
  <section class="bg-gradient-to-r from-navy-900 to-navy-800 py-16 px-4 -mt-20 pt-28">
    <div class="container mx-auto">
      <div class="max-w-3xl">
        <span class="text-gold-500 font-semibold uppercase tracking-wider text-sm" data-i18n="contact.label">
          Contacto
        </span>
        <h1 class="font-serif text-4xl md:text-5xl text-white mt-2 mb-4" data-i18n="contact.title">
          Estamos Aquí Para Ayudarte
        </h1>
        <p class="text-white/80 text-lg" data-i18n="contact.subtitle">
          ¿Tienes preguntas sobre nuestras propiedades o servicios?
          Contáctanos y te responderemos lo antes posible.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 px-4">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-1">
          <h2 class="font-serif text-2xl text-navy-900 mb-6" data-i18n="contact.info.title">Información de Contacto</h2>

          <div class="space-y-6">
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gold-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-navy-900 mb-1" data-i18n="contact.phone.label">Teléfono</h3>
                <a href="tel:+17873261547" class="text-gray-600 hover:text-gold-600">
                  (787) 326-1547
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gold-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-navy-900 mb-1" data-i18n="contact.email.label">Correo Electrónico</h3>
                <a href="mailto:info@mrtrealestate.com" class="text-gray-600 hover:text-gold-600">
                  info@mrtrealestate.com
                </a>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gold-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-navy-900 mb-1" data-i18n="contact.office.label">Oficina</h3>
                <p class="text-gray-600">
                  Arecibo, Puerto Rico
                </p>
              </div>
            </div>

            <!-- Hours -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gold-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-navy-900 mb-1" data-i18n="contact.hours.label">Horario</h3>
                <p class="text-gray-600">
                  <span data-i18n="contact.hours.weekday">Lunes - Viernes: 9am - 6pm</span><br />
                  <span data-i18n="contact.hours.saturday">Sábado: 10am - 4pm</span><br />
                  <span data-i18n="contact.hours.sunday">Domingo: Citas solamente</span>
                </p>
              </div>
            </div>
          </div>

          <!-- WhatsApp CTA -->
          <a
            href="https://wa.me/17873261547"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 w-full bg-green-500 text-white py-4 rounded-lg font-semibold hover:bg-green-600 transition-colors flex items-center justify-center gap-3"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span data-i18n="contact.whatsapp">Escríbenos por WhatsApp</span>
          </a>

          <!-- Social Media -->
          <div class="mt-8">
            <h3 class="font-semibold text-navy-900 mb-4" data-i18n="contact.follow">Síguenos</h3>
            <div class="flex gap-3">
              <a
                href="https://www.youtube.com/@mrtrealestate1547"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 bg-navy-900 text-white rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition-colors"
                aria-label="YouTube"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
              <a
                href="https://www.zillow.com/profile/MRT%20Real%20Estate"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 bg-navy-900 text-white rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition-colors"
                aria-label="Zillow"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12.006 0L1.086 8.627v3.868l3.28-2.376v10.395c0 .656.537 1.193 1.193 1.193h2.903V14.15h6.868v7.557h2.903c.656 0 1.193-.537 1.193-1.193V10.119l3.28 2.376V8.627L12.006 0z"/>
                </svg>
              </a>
              <a
                href="https://wa.me/17873261547"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 bg-navy-900 text-white rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition-colors"
                aria-label="WhatsApp"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-xl shadow-lg p-8">
            <h2 class="font-serif text-2xl text-navy-900 mb-6" data-i18n="contact.form.title">Envíanos un Mensaje</h2>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="h-96">
    <iframe
      src="https://www.openstreetmap.org/export/embed.html?bbox=-66.15%2C18.35%2C-65.95%2C18.55&layer=mapnik"
      class="w-full h-full border-0"
      loading="lazy"
      title="Ubicación de MRT Real Estate"
    ></iframe>
  </section>
</BaseLayout>
