---
import BaseLayout from '../layouts/BaseLayout.astro';
import MortgageCalculator from '../components/calculators/MortgageCalculator';
import ROICalculator from '../components/calculators/ROICalculator';
---

<BaseLayout
  title="Calculadoras"
  description="Utiliza nuestras calculadoras de hipoteca y ROI para planificar tu inversión inmobiliaria en Puerto Rico."
>
  <!-- Page Header -->
  <section class="bg-gradient-to-r from-navy-900 to-navy-800 py-16 px-4 -mt-20 pt-28">
    <div class="container mx-auto">
      <div class="max-w-3xl">
        <span class="text-gold-500 font-semibold uppercase tracking-wider text-sm">
          Herramientas
        </span>
        <h1 class="font-serif text-4xl md:text-5xl text-white mt-2 mb-4">
          Calculadoras de Inversión
        </h1>
        <p class="text-white/80 text-lg">
          Planifica tu inversión inmobiliaria con nuestras herramientas gratuitas.
          Calcula tu pago mensual de hipoteca y analiza el retorno de tu inversión.
        </p>
      </div>
    </div>
  </section>

  <!-- Calculator Navigation -->
  <section class="bg-white border-b sticky top-20 z-30">
    <div class="container mx-auto px-4">
      <nav class="flex gap-8 overflow-x-auto">
        <a
          href="#mortgage"
          class="py-4 border-b-2 border-gold-500 text-navy-900 font-medium whitespace-nowrap"
        >
          Calculadora de Hipoteca
        </a>
        <a
          href="#roi"
          class="py-4 border-b-2 border-transparent text-gray-500 hover:text-navy-900 font-medium whitespace-nowrap"
        >
          Calculadora de ROI
        </a>
      </nav>
    </div>
  </section>

  <!-- Mortgage Calculator -->
  <section id="mortgage" class="py-12 px-4 bg-gray-50">
    <div class="container mx-auto max-w-6xl">
      <MortgageCalculator client:load />
    </div>
  </section>

  <!-- ROI Calculator -->
  <section id="roi" class="py-12 px-4 bg-white">
    <div class="container mx-auto max-w-6xl">
      <ROICalculator client:load />
    </div>
  </section>

  <!-- Educational Content -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="container mx-auto max-w-4xl">
      <h2 class="font-serif text-3xl text-navy-900 mb-8 text-center">
        Guía de Inversión Inmobiliaria
      </h2>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Mortgage Guide -->
        <div class="bg-white p-6 rounded-xl shadow-lg">
          <h3 class="font-serif text-xl text-navy-900 mb-4">
            Entendiendo tu Hipoteca
          </h3>
          <div class="space-y-4 text-gray-600 text-sm">
            <div>
              <h4 class="font-semibold text-navy-900 mb-1">Principal e Interés</h4>
              <p>La porción más grande de tu pago mensual. El principal reduce tu deuda, mientras el interés es el costo del préstamo.</p>
            </div>
            <div>
              <h4 class="font-semibold text-navy-900 mb-1">Pago Inicial</h4>
              <p>Un pago inicial mayor (20%+) puede eliminar el seguro PMI y reducir tu pago mensual significativamente.</p>
            </div>
            <div>
              <h4 class="font-semibold text-navy-900 mb-1">Plazo del Préstamo</h4>
              <p>Un préstamo a 15 años tiene pagos más altos pero ahorra miles en intereses comparado con 30 años.</p>
            </div>
          </div>
        </div>

        <!-- ROI Guide -->
        <div class="bg-white p-6 rounded-xl shadow-lg">
          <h3 class="font-serif text-xl text-navy-900 mb-4">
            Métricas de Inversión
          </h3>
          <div class="space-y-4 text-gray-600 text-sm">
            <div>
              <h4 class="font-semibold text-navy-900 mb-1">Cash-on-Cash Return</h4>
              <p>Mide el retorno anual basado en el efectivo invertido. Un 8-12% se considera excelente para inversiones de renta.</p>
            </div>
            <div>
              <h4 class="font-semibold text-navy-900 mb-1">Cap Rate</h4>
              <p>Tasa de capitalización. Compara el NOI con el precio. Útil para comparar propiedades sin considerar financiamiento.</p>
            </div>
            <div>
              <h4 class="font-semibold text-navy-900 mb-1">Regla del 1%</h4>
              <p>Si la renta mensual es al menos 1% del precio de compra, la propiedad tiene buen potencial de flujo de caja.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <p class="text-gray-600 mb-4">
          ¿Necesitas ayuda con tu análisis de inversión?
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-gold-500 text-navy-900 px-8 py-3 rounded-lg font-semibold hover:bg-gold-600 transition-colors"
        >
          Consulta con un Experto
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        const offset = 100; // Account for sticky header
        const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth'
        });
      }
    });
  });

  // Update active nav on scroll
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('nav a[href^="#"]');

  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(section => {
      const sectionTop = section.offsetTop - 150;
      if (window.scrollY >= sectionTop) {
        current = section.getAttribute('id');
      }
    });

    navLinks.forEach(link => {
      link.classList.remove('border-gold-500', 'text-navy-900');
      link.classList.add('border-transparent', 'text-gray-500');
      if (link.getAttribute('href') === `#${current}`) {
        link.classList.add('border-gold-500', 'text-navy-900');
        link.classList.remove('border-transparent', 'text-gray-500');
      }
    });
  });
</script>
