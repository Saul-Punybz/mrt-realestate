---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Email - SendGrid">
  <div class="max-w-4xl">
    <!-- Info Banner -->
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6">
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-blue-700 text-sm">
          SendGrid se usa para enviar notificaciones de formularios de contacto y consultas de propiedades.
          Los mensajes se envían tanto al administrador como al cliente (auto-respuesta).
        </p>
      </div>
    </div>

    <!-- SendGrid Configuration -->
    <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
      <div class="flex items-start justify-between mb-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h2 class="font-serif text-xl text-navy-900">SendGrid</h2>
            <p class="text-gray-500 text-sm">Servicio de email transaccional</p>
          </div>
        </div>
        <span id="sendgrid-status" class="px-3 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
          No configurado
        </span>
      </div>

      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            API Key
          </label>
          <input
            type="password"
            id="sendgrid-key"
            placeholder="SG.xxxxxxxxxxxxxxxxxxxxxxxx"
            class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:border-gold-500 focus:outline-none"
          />
          <p class="text-xs text-gray-500 mt-1">Variable: SENDGRID_API_KEY</p>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Email de Origen
            </label>
            <input
              type="email"
              id="from-email"
              placeholder="noreply@mrtrealestate.com"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:border-gold-500 focus:outline-none"
            />
            <p class="text-xs text-gray-500 mt-1">Variable: FROM_EMAIL</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Email de Destino (Admin)
            </label>
            <input
              type="email"
              id="to-email"
              placeholder="info@mrtrealestate.com"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:border-gold-500 focus:outline-none"
            />
            <p class="text-xs text-gray-500 mt-1">Variable: TO_EMAIL</p>
          </div>
        </div>

        <div class="flex gap-3">
          <button
            id="save-sendgrid"
            class="bg-gold-500 text-navy-900 px-6 py-2 rounded-lg font-medium hover:bg-gold-600 transition-colors"
          >
            Guardar Configuración
          </button>
          <button
            id="test-sendgrid"
            class="border border-gray-300 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-50 transition-colors"
          >
            Enviar Email de Prueba
          </button>
        </div>
      </div>

      <!-- Instructions -->
      <div class="mt-6 pt-6 border-t border-gray-200">
        <h3 class="font-medium text-navy-900 mb-3">Cómo obtener credenciales:</h3>
        <ol class="list-decimal list-inside space-y-2 text-sm text-gray-600">
          <li>Visita <a href="https://sendgrid.com" target="_blank" class="text-gold-600 hover:underline">sendgrid.com</a> y crea una cuenta (hay plan gratuito)</li>
          <li>Ve a Settings → API Keys</li>
          <li>Crea una nueva API Key con permisos de "Mail Send"</li>
          <li>Verifica tu dominio de email en Settings → Sender Authentication</li>
          <li>Copia la API Key aquí y en las variables de Vercel</li>
        </ol>
      </div>
    </div>

    <!-- Email Templates Preview -->
    <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
      <h3 class="font-serif text-xl text-navy-900 mb-4">Plantillas de Email</h3>
      <p class="text-gray-600 text-sm mb-4">
        El sistema envía dos tipos de emails automáticamente:
      </p>

      <div class="grid md:grid-cols-2 gap-4">
        <div class="border border-gray-200 rounded-lg p-4">
          <h4 class="font-medium text-navy-900 mb-2">Notificación al Admin</h4>
          <p class="text-gray-500 text-sm mb-3">
            Cuando un usuario envía un formulario de contacto o consulta de propiedad.
          </p>
          <div class="bg-gray-50 p-3 rounded text-xs font-mono">
            <div class="text-purple-600">Asunto: Nuevo Contacto: [Nombre]</div>
            <div class="text-gray-500 mt-1">Incluye: nombre, email, teléfono, mensaje</div>
          </div>
        </div>

        <div class="border border-gray-200 rounded-lg p-4">
          <h4 class="font-medium text-navy-900 mb-2">Auto-respuesta al Cliente</h4>
          <p class="text-gray-500 text-sm mb-3">
            Confirmación automática al usuario que envió el formulario.
          </p>
          <div class="bg-gray-50 p-3 rounded text-xs font-mono">
            <div class="text-purple-600">Asunto: Gracias por contactar a MRT</div>
            <div class="text-gray-500 mt-1">Incluye: saludo, confirmación, enlaces útiles</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Vercel Environment Variables -->
    <div class="bg-navy-900 rounded-xl p-6 text-white">
      <h3 class="font-serif text-lg mb-4">Variables para Vercel</h3>
      <p class="text-gray-300 text-sm mb-4">
        Copia estas variables a tu proyecto en Vercel:
      </p>
      <pre class="bg-navy-800 p-4 rounded-lg text-sm overflow-x-auto"><code id="env-vars"># SendGrid
SENDGRID_API_KEY=SG.tu_api_key_aqui
FROM_EMAIL=noreply@mrtrealestate.com
TO_EMAIL=info@mrtrealestate.com</code></pre>
      <button
        id="copy-env"
        class="mt-4 bg-gold-500 text-navy-900 px-4 py-2 rounded-lg text-sm font-medium hover:bg-gold-600 transition-colors"
      >
        Copiar Variables
      </button>
    </div>
  </div>
</AdminLayout>

<script>
  // Load saved values
  function loadSavedValues() {
    const key = localStorage.getItem('mrt_sendgrid_key');
    const fromEmail = localStorage.getItem('mrt_from_email');
    const toEmail = localStorage.getItem('mrt_to_email');

    if (key) (document.getElementById('sendgrid-key') as HTMLInputElement).value = key;
    if (fromEmail) (document.getElementById('from-email') as HTMLInputElement).value = fromEmail;
    if (toEmail) (document.getElementById('to-email') as HTMLInputElement).value = toEmail;

    if (key) {
      const status = document.getElementById('sendgrid-status');
      if (status) {
        status.className = 'px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700';
        status.textContent = 'Configurado';
      }
    }
  }

  // Save SendGrid config
  document.getElementById('save-sendgrid')?.addEventListener('click', () => {
    const key = (document.getElementById('sendgrid-key') as HTMLInputElement).value;
    const fromEmail = (document.getElementById('from-email') as HTMLInputElement).value;
    const toEmail = (document.getElementById('to-email') as HTMLInputElement).value;

    localStorage.setItem('mrt_sendgrid_key', key);
    localStorage.setItem('mrt_from_email', fromEmail);
    localStorage.setItem('mrt_to_email', toEmail);

    if (key) {
      localStorage.setItem('mrt_email_configured', 'true');
      const status = document.getElementById('sendgrid-status');
      if (status) {
        status.className = 'px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700';
        status.textContent = 'Configurado';
      }
    }

    alert('Configuración guardada. Recuerda agregar estas variables en Vercel.');
  });

  // Test email (placeholder)
  document.getElementById('test-sendgrid')?.addEventListener('click', () => {
    alert('Para enviar un email de prueba, despliega en Vercel con las variables configuradas y usa el formulario de contacto.');
  });

  // Copy env vars
  document.getElementById('copy-env')?.addEventListener('click', () => {
    const envVars = document.getElementById('env-vars')?.textContent || '';
    navigator.clipboard.writeText(envVars);
    alert('Variables copiadas al portapapeles');
  });

  loadSavedValues();
</script>
