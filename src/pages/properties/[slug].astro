---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PropertyGallery from '../../components/properties/PropertyGallery';
import PropertyDetails from '../../components/properties/PropertyDetails';
import ContactForm from '../../components/forms/ContactForm';
import PropertyMap from '../../components/properties/PropertyMap';
import type { Property } from '../../types/property';
import { listings } from '../../data/listings';

// Generate static paths for SSG
export async function getStaticPaths() {
  return listings.map((listing) => ({
    params: { slug: listing.slug },
    props: { property: listing },
  }));
}

const { property } = Astro.props as { property: Property };

// Schema.org structured data
const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateListing',
  name: property.title,
  description: property.description,
  url: `https://mrtrealestate.com/properties/${property.slug}`,
  image: property.images,
  address: {
    '@type': 'PostalAddress',
    streetAddress: property.address.street,
    addressLocality: property.address.city,
    addressRegion: property.address.state,
    postalCode: property.address.zip,
    addressCountry: 'PR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: property.latitude,
    longitude: property.longitude,
  },
  offers: {
    '@type': 'Offer',
    price: property.price,
    priceCurrency: 'USD',
  },
  numberOfRooms: property.bedrooms,
  numberOfBathroomsTotal: property.bathrooms,
  floorSize: {
    '@type': 'QuantitativeValue',
    value: property.squareFeet,
    unitCode: 'FTK',
  },
};
---

<BaseLayout
  title={property.title}
  description={property.description.substring(0, 160)}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <!-- Breadcrumb -->
  <nav class="bg-gray-100 py-3 px-4">
    <div class="container mx-auto">
      <ol class="flex items-center gap-2 text-sm">
        <li>
          <a href="/" class="text-gray-500 hover:text-navy-900">Inicio</a>
        </li>
        <li class="text-gray-400">/</li>
        <li>
          <a href="/properties" class="text-gray-500 hover:text-navy-900">Propiedades</a>
        </li>
        <li class="text-gray-400">/</li>
        <li class="text-navy-900 font-medium">{property.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Property Header -->
  <section class="py-6 px-4 bg-white border-b">
    <div class="container mx-auto">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <div class="flex items-center gap-3 mb-2">
            {property.newListing && (
              <span class="bg-gold-500 text-navy-900 px-3 py-1 rounded-full text-xs font-bold uppercase">
                Nueva
              </span>
            )}
            {property.featured && (
              <span class="bg-navy-900 text-white px-3 py-1 rounded-full text-xs font-bold uppercase">
                Destacada
              </span>
            )}
            <span class="text-gray-500 text-sm">MLS# {property.mlsNumber}</span>
          </div>
          <h1 class="font-serif text-3xl md:text-4xl text-navy-900 mb-2">
            {property.title}
          </h1>
          <p class="text-gray-600 flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {property.address.full}
          </p>
        </div>
        <div class="text-right">
          <div class="font-serif text-3xl md:text-4xl font-bold text-gold-600 mb-1">
            ${property.price.toLocaleString()}{property.status === 'Rental' ? '/mes' : ''}
          </div>
          {property.squareFeet < 50000 && property.squareFeet > 0 && (
            <div class="text-gray-500 text-sm">
              ${Math.round(property.price / property.squareFeet).toLocaleString()} / ft²
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="bg-gray-100">
    <PropertyGallery client:load images={property.images} title={property.title} />
  </section>

  <!-- Main Content -->
  <section class="py-12 px-4">
    <div class="container mx-auto">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Left Column - Details -->
        <div class="lg:w-2/3">
          <PropertyDetails client:load property={property} />
        </div>

        <!-- Right Column - Contact & Map -->
        <div class="lg:w-1/3">
          <div class="sticky top-24 space-y-6">
            <!-- Contact Form -->
            <div class="bg-white rounded-xl shadow-lg p-6">
              <h3 class="font-serif text-xl font-semibold text-navy-900 mb-4">
                ¿Interesado en esta propiedad?
              </h3>
              <ContactForm client:load propertyId={property.id} propertyTitle={property.title} />
            </div>

            <!-- Map -->
            <div class="bg-white rounded-xl shadow-lg overflow-hidden">
              <PropertyMap
                client:load
                latitude={property.latitude}
                longitude={property.longitude}
                address={property.address.full}
              />
            </div>

            <!-- Agent Info -->
            <div class="bg-white rounded-xl shadow-lg p-6">
              <div class="flex items-center gap-4 mb-4">
                <img
                  src="/images/team/marilyn.jpeg"
                  alt="Marilyn Rivera"
                  class="w-16 h-16 rounded-full object-cover"
                />
                <div>
                  <h4 class="font-semibold text-navy-900">Marilyn Rivera</h4>
                  <p class="text-gray-500 text-sm">Agente Principal</p>
                </div>
              </div>
              <div class="space-y-2 text-sm">
                <a href="tel:+17879398739" class="flex items-center gap-2 text-gray-600 hover:text-navy-900">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  (787) 939-8739
                </a>
                <a href="mailto:info@mrtrealestate.com" class="flex items-center gap-2 text-gray-600 hover:text-navy-900">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  info@mrtrealestate.com
                </a>
              </div>
              <a
                href="https://wa.me/17879398739"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 w-full bg-green-500 text-white py-3 rounded-lg font-medium hover:bg-green-600 transition-colors flex items-center justify-center gap-2"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
