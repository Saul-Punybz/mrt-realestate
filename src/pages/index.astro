---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import FeaturedProperties from '../components/home/FeaturedProperties';
import Stats from '../components/home/Stats.astro';
---

<BaseLayout
  title="Inicio"
  description="MRT Real Estate - Tu socio de confianza en bienes raíces en Puerto Rico. Descubre propiedades premium en las mejores ubicaciones."
>
  <!-- Hero Section -->
  <Hero />

  <!-- Featured Properties -->
  <FeaturedProperties client:load />

  <!-- Stats Section -->
  <Stats />

  <!-- Services Section -->
  <section class="py-20 px-4">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <span class="text-gold-600 font-semibold uppercase tracking-wider text-sm" data-i18n="services.label">
          Nuestros Servicios
        </span>
        <h2 class="font-serif text-4xl md:text-5xl text-navy-900 mt-2 mb-4" data-i18n="services.title">
          ¿Cómo Podemos Ayudarte?
        </h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto" data-i18n="services.subtitle">
          Ofrecemos un servicio integral para todas tus necesidades inmobiliarias
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Buy -->
        <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition-shadow group">
          <div class="w-16 h-16 bg-gold-100 rounded-full flex items-center justify-center mb-6 group-hover:bg-gold-500 transition-colors">
            <svg class="w-8 h-8 text-gold-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl font-semibold text-navy-900 mb-3" data-i18n="services.buy.title">
            Compra tu Hogar
          </h3>
          <p class="text-gray-600 mb-6" data-i18n="services.buy.desc">
            Encuentra la propiedad perfecta con nuestra amplia selección de casas,
            apartamentos y villas en Puerto Rico.
          </p>
          <a href="/properties" class="text-gold-600 font-semibold hover:text-navy-900 transition-colors inline-flex items-center gap-2">
            <span data-i18n="services.buy.cta">Ver Propiedades</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Sell -->
        <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition-shadow group">
          <div class="w-16 h-16 bg-gold-100 rounded-full flex items-center justify-center mb-6 group-hover:bg-gold-500 transition-colors">
            <svg class="w-8 h-8 text-gold-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl font-semibold text-navy-900 mb-3" data-i18n="services.sell.title">
            Vende tu Propiedad
          </h3>
          <p class="text-gray-600 mb-6" data-i18n="services.sell.desc">
            Obtén el mejor valor por tu propiedad con nuestro equipo de expertos
            y estrategias de marketing efectivas.
          </p>
          <a href="/sell" class="text-gold-600 font-semibold hover:text-navy-900 transition-colors inline-flex items-center gap-2">
            <span data-i18n="services.sell.cta">Evalúa tu Propiedad</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Invest -->
        <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition-shadow group">
          <div class="w-16 h-16 bg-gold-100 rounded-full flex items-center justify-center mb-6 group-hover:bg-gold-500 transition-colors">
            <svg class="w-8 h-8 text-gold-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl font-semibold text-navy-900 mb-3" data-i18n="services.invest.title">
            Invierte con Nosotros
          </h3>
          <p class="text-gray-600 mb-6" data-i18n="services.invest.desc">
            Maximiza tu retorno con nuestras calculadoras de inversión y
            asesoría especializada en el mercado de PR.
          </p>
          <a href="/calculators" class="text-gold-600 font-semibold hover:text-navy-900 transition-colors inline-flex items-center gap-2">
            <span data-i18n="services.invest.cta">Ver Calculadoras</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- YouTube Videos Section -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <span class="text-gold-600 font-semibold uppercase tracking-wider text-sm" data-i18n="videos.label">
          Videos
        </span>
        <h2 class="font-serif text-4xl md:text-5xl text-navy-900 mt-2 mb-4" data-i18n="videos.title">
          Conoce Más Sobre Bienes Raíces
        </h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto" data-i18n="videos.subtitle">
          Contenido educativo para compradores, vendedores e inversionistas
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="rounded-xl overflow-hidden shadow-lg bg-white">
          <div class="aspect-video">
            <iframe
              src="https://www.youtube.com/embed/tXPmZvHG4FE"
              title="Los 10 pasos para comprar una casa en Puerto Rico"
              class="w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
        <div class="rounded-xl overflow-hidden shadow-lg bg-white">
          <div class="aspect-video">
            <iframe
              src="https://www.youtube.com/embed/AolFMblB_F8"
              title="MRT Real Estate"
              class="w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
        <div class="rounded-xl overflow-hidden shadow-lg bg-white">
          <div class="aspect-video">
            <iframe
              src="https://www.youtube.com/embed/gULvJo34bzY"
              title="MRT Real Estate"
              class="w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>

      <div class="text-center mt-10">
        <a
          href="https://www.youtube.com/@mrtrealestate1547"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-navy-900 text-white px-6 py-3 rounded-lg font-semibold hover:bg-gold-500 hover:text-navy-900 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <span data-i18n="videos.cta">Ver Todos los Videos</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 bg-gradient-to-r from-navy-900 to-navy-800 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img
        src="/images/listings/mountain-estate-2.jpg"
        alt=""
        class="w-full h-full object-cover"
      />
    </div>
    <div class="container mx-auto relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-serif text-4xl md:text-5xl text-white mb-6">
          <span data-i18n="cta.title1">¿Listo para encontrar tu</span>
          <span class="text-gold-500" data-i18n="cta.title2">hogar ideal</span>?
        </h2>
        <p class="text-white/80 text-lg mb-8" data-i18n="cta.subtitle">
          Contáctanos hoy y permítenos ayudarte a hacer realidad tu sueño de tener
          la propiedad perfecta en Puerto Rico.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="bg-gold-500 text-navy-900 px-8 py-4 rounded-lg font-bold hover:bg-white transition-colors"
            data-i18n="cta.button"
          >
            Contáctanos Ahora
          </a>
          <a
            href="https://wa.me/17873261547"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-transparent border-2 border-white text-white px-8 py-4 rounded-lg font-bold hover:bg-white hover:text-navy-900 transition-colors inline-flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Locations Section -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <span class="text-gold-600 font-semibold uppercase tracking-wider text-sm" data-i18n="locations.label">
          Ubicaciones
        </span>
        <h2 class="font-serif text-4xl md:text-5xl text-navy-900 mt-2 mb-4" data-i18n="locations.title">
          Explora Puerto Rico
        </h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto" data-i18n="locations.subtitle">
          Propiedades en todo Puerto Rico, incluyendo Vieques y Culebra
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { name: 'Arecibo', image: '/images/listings/ready-house-1.jpg', count: 6 },
          { name: 'Utuado', image: '/images/listings/historic-utuado-1.jpg', count: 8 },
          { name: 'Lares', image: '/images/listings/hacienda-iberia-1.jpg', count: 3 },
          { name: 'Ciales', image: '/images/listings/mountain-estate-1.jpg', count: 2 },
        ].map((location) => (
          <a
            href={`/properties?city=${location.name.toLowerCase()}`}
            class="relative group rounded-xl overflow-hidden aspect-square"
          >
            <img
              src={location.image}
              alt={location.name}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-900/80 to-transparent"></div>
            <div class="absolute bottom-4 left-4 text-white">
              <h3 class="font-serif text-xl font-semibold">{location.name}</h3>
              <p class="text-white/80 text-sm">{location.count} <span data-i18n="locations.count">propiedades</span></p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
