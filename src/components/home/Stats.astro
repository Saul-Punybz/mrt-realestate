---
const stats = [
  {
    value: '$500M+',
    label: 'En Ventas',
    description: 'Volumen total de transacciones',
  },
  {
    value: '1,200+',
    label: 'Propiedades Vendidas',
    description: 'Clientes satisfechos',
  },
  {
    value: '15+',
    label: 'Años de Experiencia',
    description: 'En el mercado de PR',
  },
  {
    value: '98%',
    label: 'Satisfacción',
    description: 'Recomendaciones de clientes',
  },
];
---

<section class="py-20 bg-navy-900 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"1\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-gold-500 mb-2">
            {stat.value}
          </div>
          <div class="text-white text-lg font-semibold mb-1">
            {stat.label}
          </div>
          <div class="text-gray-400 text-sm">
            {stat.description}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
