---
const navLinks = [
  { href: '/', label: 'Inicio', i18nKey: 'nav.inicio' },
  { href: '/properties', label: 'Propiedades', i18nKey: 'nav.propiedades' },
  { href: '/sell', label: 'Vende tu Propiedad', i18nKey: 'nav.vende' },
  { href: '/calculators', label: 'Calculadoras', i18nKey: 'nav.calculadoras' },
  { href: '/about', label: 'Nosotros', i18nKey: 'nav.nosotros' },
  { href: '/blog', label: 'Blog', i18nKey: 'nav.blog' },
  { href: '/contact', label: 'Contacto', i18nKey: 'nav.contacto' },
];

const currentPath = Astro.url.pathname;
---

<nav class="hidden lg:block">
  <ul class="flex items-center gap-6">
    {navLinks.map(({ href, label, i18nKey }) => (
      <li>
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors relative',
            'hover:text-gold-500',
            currentPath === href ? 'text-gold-500' : 'text-white',
          ]}
          data-i18n={i18nKey}
        >
          {label}
          {currentPath === href && (
            <span class="absolute -bottom-1 left-0 right-0 h-0.5 bg-gold-500"></span>
          )}
        </a>
      </li>
    ))}
  </ul>
</nav>
