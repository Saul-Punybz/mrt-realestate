---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/properties', label: 'Ver Propiedades', i18nKey: 'footer.links.propiedades' },
  { href: '/sell', label: 'Vende tu Propiedad', i18nKey: 'footer.links.vende' },
  { href: '/calculators', label: 'Calculadoras', i18nKey: 'footer.links.calculadoras' },
  { href: '/about', label: 'Sobre Nosotros', i18nKey: 'footer.links.nosotros' },
  { href: '/contact', label: 'Contacto', i18nKey: 'footer.links.contacto' },
  { href: '/blog', label: 'Blog', i18nKey: 'footer.links.blog' },
];

const propertyTypes = [
  { href: '/properties?type=casa', label: 'Casas', i18nKey: 'footer.properties.casas' },
  { href: '/properties?type=apartamento', label: 'Apartamentos', i18nKey: 'footer.properties.apartamentos' },
  { href: '/properties?type=comercial', label: 'Comercial', i18nKey: 'footer.properties.comercial' },
  { href: '/properties?type=terreno', label: 'Terrenos', i18nKey: 'footer.properties.terrenos' },
  { href: '/properties?type=multi-familiar', label: 'Multi-Familiar', i18nKey: 'footer.properties.multifamiliar' },
  { href: '/properties?type=finca', label: 'Fincas', i18nKey: 'footer.properties.fincas' },
];

const locations = [
  { href: '/properties?city=san-juan', label: 'San Juan' },
  { href: '/properties?city=arecibo', label: 'Arecibo' },
  { href: '/properties?city=ponce', label: 'Ponce' },
  { href: '/properties?city=mayaguez', label: 'Mayagüez' },
  { href: '/properties?city=caguas', label: 'Caguas' },
  { href: '/properties?city=guaynabo', label: 'Guaynabo' },
  { href: '/properties?city=dorado', label: 'Dorado' },
  { href: '/properties?city=rincon', label: 'Rincón' },
  { href: '/properties?city=vieques', label: 'Vieques' },
  { href: '/properties?city=culebra', label: 'Culebra' },
];
---

<footer class="bg-navy-900 text-white">
  <!-- Agent/Broker Resources Banner -->
  <div class="bg-gradient-to-r from-gold-600 to-gold-500">
    <div class="container mx-auto px-4 py-5">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="font-serif text-lg font-bold text-navy-900" data-i18n="footer.broker.title">Para Corredores y Agentes</h3>
          <p class="text-navy-900/70 text-sm" data-i18n="footer.broker.desc">Recursos profesionales para la comunidad inmobiliaria</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/co-broke" class="bg-navy-900 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-white hover:text-navy-900 transition-colors">
            Co-Broke Policy
          </a>
          <a href="/showing" class="bg-navy-900 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-white hover:text-navy-900 transition-colors" data-i18n="footer.broker.showing">
            Solicitar Showing
          </a>
          <a href="/edi" class="bg-navy-900 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-white hover:text-navy-900 transition-colors">
            EDI
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Company Info -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-gold-500 rounded-full flex items-center justify-center">
            <span class="text-navy-900 font-serif font-bold text-xl">MRT</span>
          </div>
          <div>
            <span class="font-serif text-xl font-semibold">MRT Real Estate</span>
            <span class="block text-gold-500 text-xs tracking-wider">PUERTO RICO</span>
          </div>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-4" data-i18n="footer.company.desc">
          Tu socio de confianza en bienes raíces en todo Puerto Rico,
          incluyendo Vieques y Culebra. Servicio personalizado
          para encontrar tu hogar ideal.
        </p>
        <div class="flex items-center gap-2 mb-6">
          <svg class="w-4 h-4 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
          </svg>
          <span class="text-gray-400 text-xs" data-i18n="header.idiomas">Español · English · Italiano</span>
        </div>
        <div class="flex gap-4">
          <a href="https://www.youtube.com/@mrtrealestate1547" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-navy-800 rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition-colors" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a href="https://www.zillow.com/profile/MRT%20Real%20Estate" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-navy-800 rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition-colors" aria-label="Zillow">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.006 0L1.086 8.627v3.868l3.28-2.376v10.395c0 .656.537 1.193 1.193 1.193h2.903V14.15h6.868v7.557h2.903c.656 0 1.193-.537 1.193-1.193V10.119l3.28 2.376V8.627L12.006 0z"/>
            </svg>
          </a>
          <a href="https://wa.me/17873261547" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-navy-800 rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 transition-colors" aria-label="WhatsApp">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-serif font-semibold mb-6 text-gold-500" data-i18n="footer.links.title">Enlaces Rápidos</h3>
        <ul class="space-y-3">
          {quickLinks.map(({ href, label, i18nKey }) => (
            <li>
              <a href={href} class="text-gray-400 hover:text-gold-500 transition-colors text-sm" data-i18n={i18nKey}>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Property Types & Locations -->
      <div>
        <h3 class="text-lg font-serif font-semibold mb-6 text-gold-500" data-i18n="footer.properties.title">Propiedades</h3>
        <ul class="space-y-3 mb-6">
          {propertyTypes.map(({ href, label, i18nKey }) => (
            <li>
              <a href={href} class="text-gray-400 hover:text-gold-500 transition-colors text-sm" data-i18n={i18nKey}>
                {label}
              </a>
            </li>
          ))}
        </ul>
        <h4 class="text-sm font-semibold text-gold-500/70 uppercase tracking-wider mb-3" data-i18n="footer.locations.label">Servicio en Todo Puerto Rico</h4>
        <div class="flex flex-wrap gap-2">
          {locations.map(({ href, label }) => (
            <a href={href} class="text-gray-500 hover:text-gold-500 transition-colors text-xs bg-navy-800 px-2 py-1 rounded">
              {label}
            </a>
          ))}
        </div>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-serif font-semibold mb-6 text-gold-500" data-i18n="footer.contact.title">Contacto</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-gray-400 text-sm">
              Arecibo, Puerto Rico
            </span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+17873261547" class="text-gray-400 hover:text-gold-500 transition-colors text-sm">
              (787) 326-1547
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:marilyn@mrtrealestate.com" class="text-gray-400 hover:text-gold-500 transition-colors text-sm">
              marilyn@mrtrealestate.com
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-navy-800">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="text-center md:text-left">
          <p class="text-gray-500 text-sm">
            &copy; {currentYear} MRT Real Estate Puerto Rico. <span data-i18n="footer.copyright">Todos los derechos reservados.</span>
          </p>
          <p class="text-gray-600 text-xs mt-1">
            Marilyn Rivera — Lic. C-19882
          </p>
        </div>
        <div class="flex gap-6 text-sm">
          <a href="/admin" class="text-gray-600 hover:text-gold-500 transition-colors">
            Admin
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
